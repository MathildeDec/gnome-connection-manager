# --- Traductions principales ---

msgid "Copiar"
msgstr "Kopier"

msgid "Pegar"
msgstr "Lim inn"

msgid "Seleccionar todo"
msgstr "Merk alt"

msgid "Copiar y Pegar"
msgstr "Kopier og lim inn"

msgid "Reiniciar consola"
msgstr "Start terminal på nytt"

msgid "Reiniciar y Limpiar consola"
msgstr "Start på nytt og tøm"

msgid "Clonar consola"
msgstr "Klon terminal"

msgid "Cerrar consola"
msgstr "Lukk terminal"

msgid "Renombrar consola"
msgstr "Gi terminal nytt navn"

msgid "Guardar"
msgstr "Lagre"

msgid "Cancelar"
msgstr "Avbryt"

msgid "Aceptar"
msgstr "OK"

msgid "Nunca"
msgstr "Aldri"

msgid "Siempre"
msgstr "Alltid"

msgid "Sólo si no hay errores"
msgstr "Bare uten feil"

msgid "Abrir"
msgstr "Åpne"

msgid "Cerrar"
msgstr "Lukk"

msgid "Error"
msgstr "Feil"

msgid "Abrir consola local al inicio"
msgstr "Åpne lokal terminal ved oppstart"

msgid "Log consola local"
msgstr "Lokal terminallogg"

msgid "Pegar con botón derecho"
msgstr "Høyreklikk for å lime inn"

msgid "Confirmar al cerrar una consola"
msgstr "Bekreft lukking av terminal"

msgid "Confirmar al cerrar una consola con botón central del mouse"
msgstr "Bekreft lukking med midtknapp"

msgid "Confirmar al salir"
msgstr "Bekreft avslutning"

msgid "Comprobar actualizaciones"
msgstr "Se etter oppdateringer"

msgid "Deshabilitar franjas alternas en la ventana de hosts"
msgstr "Deaktiver annenhver rad i vertslisten"

msgid "No hay consolas abiertas"
msgstr "Ingen åpne terminaler"

msgid "Los campos grupo, nombre y host son obligatorios"
msgstr "Feltene gruppe, navn og vert er obligatoriske"

msgid "ya existe para el grupo"
msgstr "finnes allerede for gruppen"

msgid "Error al guardar el host. Descripcion"
msgstr "Feil ved lagring av vert. Beskrivelse"

msgid "Error al conectar con servidor"
msgstr "Feil ved tilkobling til server"

msgid "consolas abiertas, confirma que desea salir?"
msgstr "Terminaler er åpne. Bekreft avslutning?"

msgid "Confirma que desea eliminar todos los hosts del grupo"
msgstr "Fjerne alle verter fra gruppen?"

msgid "Crear redirección dinámica de puertos"
msgstr "Opprett dynamisk portviderekobling"

msgid "Dejar en blanco para autenticación sin password/public key"
msgstr "La stå tomt for autentisering uten passord/offentlig nøkkel"

msgid "Usar formato grupo1/grupo2/grupo3 para crear subgrupos"
msgstr "Bruk gruppe1/gruppe2/gruppe3-format for undergrupper"

msgid "Opciones extra"
msgstr "Ekstra alternativer"

msgid "Annuler"
msgstr "Avbryt"

msgid "Enregistrer"
msgstr "Lagre"

msgid "Ouvrir"
msgstr "Åpne"

msgid "_Archivo"
msgstr "_Fil"

msgid "_Editar"
msgstr "_Rediger"

msgid "_Servidores"
msgstr "_Servere"

msgid "_Ayuda"
msgstr "_Hjelp"

# --- Strings v1.3 (RDP, libvirt, XEmbed) ---

msgid "Connecter"
msgstr "Koble til"

msgid "Deconnecter"
msgstr "Koble fra"

msgid "En attente…"
msgstr "Venter…"

msgid "Connexion en cours…"
msgstr "Kobler til…"

msgid "Session terminée"
msgstr "Økt avsluttet"

msgid "xfreerdp introuvable"
msgstr "xfreerdp ikke funnet"

msgid "Déconnecté"
msgstr "Frakoblet"

msgid "Connecté"
msgstr "Tilkoblet"

msgid "Terminé (code {rc})"
msgstr "Avsluttet (kode {rc})"

msgid "Options xfreerdp :"
msgstr "xfreerdp-alternativer:"

msgid "Journal xfreerdp :"
msgstr "xfreerdp-logg:"

msgid "Importer depuis libvirt"
msgstr "Importer fra libvirt"

msgid "User SSH pour les VMs :"
msgstr "SSH-bruker for VM-er:"

msgid "Hyperviseurs (virt-manager / dconf) :"
msgstr "Hypervisorer (virt-manager / dconf):"

msgid "URI libvirt"
msgstr "libvirt URI"

msgid "Aucun hôte importé."
msgstr "Ingen vert importert."

msgid "Libvirt"
msgstr "Libvirt"

msgid "Utilisateur SSH par défaut (VMs) :"
msgstr "Standard SSH-bruker (VM-er):"

msgid "Une nouvelle version est disponible : https://github.com/MathildeDec/gnome-connection-manager/releases"
msgstr "Ny versjon tilgjengelig: https://github.com/MathildeDec/gnome-connection-manager/releases"
