msgid "Flow control:"
msgstr "Έλεγχος ροής:"

#: gnome_connection_manager.py:1939
msgid ""
"Flow control:\n"
"  None = standard console\n"
"  XON/XOFF = software (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = hardware (full cable)\n"
"  DSR/DTR = legacy hardware"
msgstr ""
"Έλεγχος ροής:\n"
"  Κανένας = τυπική κονσόλα\n"
"  XON/XOFF = λογισμικό (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = υλικό (πλήρες καλώδιο)\n"
"  DSR/DTR = παλαιό υλικό"

#: gnome_connection_manager.py:1955
msgid ""
"Additional raw options passed to the binary\n"
"Ex: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"
msgstr ""
"Πρόσθετες ανεπεξέργαστες επιλογές που μεταβιβάζονται στο πρόγραμμα\n"
"Π.χ.: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"

#: gnome_connection_manager.py:2923 gnome_connection_manager.py:2972
