msgstr "โหลดการตั้งค่าซีเรียลที่ผู้ผลิตแนะนำ"

#: gnome_connection_manager.py:1899
msgid "Data bits:"
msgstr "บิตข้อมูล:"

#: gnome_connection_manager.py:1905
msgid "Number of data bits per byte (8 = standard)"
msgstr "จำนวนบิตข้อมูลต่อไบต์ (8 = มาตรฐาน)"

#: gnome_connection_manager.py:1910
msgid "Parity:"
msgstr "พาริตี:"

#: gnome_connection_manager.py:1916
msgid "Parity bit: None (N) = standard, Even (E), Odd (O)"
msgstr "บิตพาริตี: ไม่มี (N) = มาตรฐาน, คู่ (E), คี่ (O)"

#: gnome_connection_manager.py:1921
msgid "Stop bits:"
msgstr "บิตหยุด:"

#: gnome_connection_manager.py:1927
msgid "Stop bits: 1 = standard, 2 = RS-485 / legacy hardware"
msgstr "บิตหยุด: 1 = มาตรฐาน, 2 = RS-485 / ฮาร์ดแวร์รุ่นเก่า"

#: gnome_connection_manager.py:1932
msgid "Flow control:"
msgstr "การควบคุมการรับส่งข้อมูล:"

#: gnome_connection_manager.py:1939
msgid ""
"Flow control:\n"
"  None = standard console\n"
"  XON/XOFF = software (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = hardware (full cable)\n"
"  DSR/DTR = legacy hardware"
msgstr ""
"การควบคุมการรับส่งข้อมูล:\n"
"  ไม่มี = คอนโซลมาตรฐาน\n"
"  XON/XOFF = ซอฟต์แวร์ (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = ฮาร์ดแวร์ (สายเต็ม)\n"
"  DSR/DTR = ฮาร์ดแวร์รุ่นเก่า"

#: gnome_connection_manager.py:1955
msgid ""
"Additional raw options passed to the binary\n"
"Ex: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"
msgstr ""
"ตัวเลือกดิบเพิ่มเติมที่ส่งไปยังโปรแกรม\n"
"ตัวอย่าง: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"

#: gnome_connection_manager.py:2923 gnome_connection_manager.py:2972
