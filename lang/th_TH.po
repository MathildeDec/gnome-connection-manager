msgid "Add"
msgstr "เพิ่ม"

#: gnome_connection_manager.py:2988
msgid "<b>Connection types to import:</b>"
msgstr "<b>ประเภทการเชื่อมต่อที่จะนำเข้า:</b>"

#: gnome_connection_manager.py:2995
msgid ""
"SSH  (ProxyJump -J via hypervisor when VM IP is known, otherwise hypervisor "
"shell + -t ssh user@vm)"
msgstr ""
"SSH  (ProxyJump -J ผ่านไฮเปอร์ไวเซอร์เมื่อทราบ IP ของ VM "
"มิฉะนั้นใช้เชลล์ไฮเปอร์ไวเซอร์ + -t ssh user@vm)"

#: gnome_connection_manager.py:3002
msgid ""
"SPICE  (virt-viewer --connect qemu+ssh://... vm - SSH tunnel handled "
"automatically)"
msgstr ""
"SPICE  (virt-viewer --connect qemu+ssh://... vm - จัดการทันเนล SSH "
"โดยอัตโนมัติ)"

#: gnome_connection_manager.py:3008
msgid ""
"RDP  (probe port 3389 from hypervisor via nc/nmap - skipped if port is "
"closed)"
msgstr ""
"RDP  (ตรวจสอบพอร์ต 3389 จากไฮเปอร์ไวเซอร์ผ่าน nc/nmap - ข้ามไปหากพอร์ตปิด)"

#: gnome_connection_manager.py:3036
