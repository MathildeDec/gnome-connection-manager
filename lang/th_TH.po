msgid "Detected libvirt URI"
msgstr "ตรวจพบ URI ของ libvirt"

#: gnome_connection_manager.py:2977
msgid ""
"Ex: 192.168.105.41 | root@192.168.105.41 | "
"qemu+ssh://root@192.168.105.41/system"
msgstr ""
"ตัวอย่าง: 192.168.105.41 | root@192.168.105.41 | "
"qemu+ssh://root@192.168.105.41/system"

