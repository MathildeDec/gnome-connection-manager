msgstr "<b>आयात करने के लिए कनेक्शन प्रकार:</b>"

#: gnome_connection_manager.py:2995
msgid ""
"SSH  (ProxyJump -J via hypervisor when VM IP is known, otherwise hypervisor "
"shell + -t ssh user@vm)"
msgstr ""
"SSH (यदि VM का IP पता है तो हाइपरवाइज़र के माध्यम से ProxyJump -J, अन्यथा "
"हाइपरवाइज़र शेल + -t ssh user@vm)"

#: gnome_connection_manager.py:3002
msgid ""
"SPICE  (virt-viewer --connect qemu+ssh://... vm - SSH tunnel handled "
"automatically)"
msgstr ""
"SPICE (virt-viewer --connect qemu+ssh://... vm - SSH टनल स्वतः संभाला जाता "
"है)"

#: gnome_connection_manager.py:3008
msgid ""
"RDP  (probe port 3389 from hypervisor via nc/nmap - skipped if port is "
"closed)"
msgstr ""
"RDP (हाइपरवाइज़र से nc/nmap के माध्यम से पोर्ट 3389 की जांच - पोर्ट बंद होने"
" पर छोड़ा जाता है)"

