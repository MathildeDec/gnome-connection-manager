msgid "Stop bits: 1 = standard, 2 = RS-485 / legacy hardware"
msgstr "स्टॉप बिट्स: 1 = स्टैंडर्ड, 2 = RS-485 / लीगेसी हार्डवेयर"

#: gnome_connection_manager.py:1932
msgid "Flow control:"
msgstr "फ्लो कंट्रोल:"

#: gnome_connection_manager.py:1939
msgid ""
"Flow control:\n"
"  None = standard console\n"
"  XON/XOFF = software (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = hardware (full cable)\n"
"  DSR/DTR = legacy hardware"
msgstr ""
"फ्लो कंट्रोल:\n"
"  कोई नहीं = स्टैंडर्ड कंसोल\n"
"  XON/XOFF = सॉफ्टवेयर (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = हार्डवेयर (पूर्ण केबल)\n"
"  DSR/DTR = लीगेसी हार्डवेयर"

#: gnome_connection_manager.py:1955
msgid ""
"Additional raw options passed to the binary\n"
"Ex: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"
msgstr ""
"बाइनरी को पास किए गए अतिरिक्त रॉ विकल्प\n"
"उदा: --logfile /tmp/serial.log (picocom)\n"
"     -o -x (minicom)"

#: gnome_connection_manager.py:2923 gnome_connection_manager.py:2972
