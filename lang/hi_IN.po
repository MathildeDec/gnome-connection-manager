msgid ""
"Ex: 192.168.105.41 | root@192.168.105.41 | "
"qemu+ssh://root@192.168.105.41/system"
msgstr ""
"उदा: 192.168.105.41 | root@192.168.105.41 | "
"qemu+ssh://root@192.168.105.41/system"

