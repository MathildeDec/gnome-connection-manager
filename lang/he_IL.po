msgid "Flow control:"
msgstr "בקרת זרימה:"

#: gnome_connection_manager.py:1939
msgid ""
"Flow control:\n"
"  None = standard console\n"
"  XON/XOFF = software (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = hardware (full cable)\n"
"  DSR/DTR = legacy hardware"
msgstr ""
"בקרת זרימה:\n"
"  ללא = מסוף סטנדרטי\n"
"  XON/XOFF = תוכנה (Ctrl-Q/Ctrl-S)\n"
"  RTS/CTS = חומרה (כבל מלא)\n"
"  DSR/DTR = חומרה ישנה"

#: gnome_connection_manager.py:1955
msgid ""
"Additional raw options passed to the binary\n"
"Ex: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"
msgstr ""
"אפשרויות גולמיות נוספות המועברות לתוכנה\n"
"לדוגמה: --logfile /tmp/serial.log  (picocom)\n"
"     -o -x  (minicom)"

